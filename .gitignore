# selectively un-ignore the specific demo fixtures used by the deployed
# Streamlit app's fallback path. Future fresh-scan CSVs remain ignored.
data/nba/projections/*
!data/nba/projections/scan_2026-05-09.csv
!data/nba/projections/scan_2026-05-10.csv

# Model binaries (regenerate with train.py)
models/nba/*.json

